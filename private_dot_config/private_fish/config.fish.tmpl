if status is-interactive
    # Commands to run in interactive sessions can go here
end

set fish_greeting

set EZA_CONFIG_DIR ~/.config/eza

fish_add_path /opt/homebrew/bin
fish_add_path /opt/homebrew/sbin
fish_add_path ~/.local/bin
fish_add_path ~/.krew/bin

{{- if .is_work }}

set -gx SRC_ENDPOINT {{ .src_endpoint }}
set -gx SRC_ACCESS_TOKEN {{ .src_access_token }}

set -gx JIRA_USER {{ .jira_user }}
set -gx JIRA_TOKEN {{ .jira_token }}

fish_add_path {{ .work_bin_path }}

set -gx LITE_LLM_API_KEY {{ .litellm_api_key }}

eval (ai-env)
{{- end }}

set -gx EDITOR nvim

# Claude Code via cmux agent teams
if set -q CMUX_WORKSPACE_ID
    alias c 'cmux claude-teams --dangerously-skip-permissions'
    alias claude-teams 'cmux claude-teams'
    alias cy 'claude --dangerously-skip-permissions'
end

set fish_cursor_default block
starship init fish | source

if test -d ~/.cache/lm-studio/bin
    fish_add_path ~/.cache/lm-studio/bin
end

zoxide init fish | source

if command -v wt >/dev/null 2>&1; eval (command wt config shell init fish); end
