[nodejs]
symbol = ""
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[nim]
symbol = "󰆥 "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[rust]
symbol = ""
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[scala]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[time]
disabled = false
time_format = "%R" # Hour:Minute Format
style = "bg:red fg:black"
format = '[ $time ]($style)'
