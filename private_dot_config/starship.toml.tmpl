format = """
[](bright-black)\
$os\
$shell\
$username\
[](bg:blue fg:bright-black)\
$directory\
[](fg:blue bg:green)\
$git_branch\
$git_status\
[](fg:green bg:yellow)\
$c\
$elixir\
$elm\
$golang\
$gradle\
$haskell\
$java\
$julia\
$python\
$bun\
$nodejs\
$nim\
$rust\
$scala\
[](fg:yellow bg:purple)\
$docker_context\
$kubernetes\
[](fg:purple bg:red)\
$time\
[ ](fg:red)\
"""

# Disable the blank line at the start of the prompt
# add_newline = false

# You can also replace your username with a neat symbol like   or disable this
# and use the os module below
[username]
show_always = false
style_user = "bg:bright-black fg:bright-white"
style_root = "bg:bright-black fg:bright-white"
format = '[$user ]($style)'
disabled = true

# An alternative to the username module which displays a symbol that
# represents the current operating system
[os]
style = "bg:bright-black fg:bright-white"
disabled = true # Disabled by default
[os.symbols]
Macos = " "

[shell]
format = '[$indicator ]($style)'
fish_indicator = '󰈺'
powershell_indicator = '_'
zsh_indicator = '󰬡'
bash_indicator = '󱆃'
nu_indicator = ''
unknown_indicator = ''
style = "bg:bright-black fg:bright-white"
disabled = false

[directory]
style = "bg:blue fg:black"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "…/"

# Here is how you can shorten some long paths by text replacement
# similar to mapped_locations in Oh My Posh:
[directory.substitutions]
"projects" = " "
"Documents" = "󰈙 "
"Downloads" = " "
"Music" = " "
"Pictures" = " "
# Keep in mind that the order matters. For example:
# "Important Documents" = " 󰈙 "
# will not be replaced, because "Documents" was already substituted before.
# So either put "Important Documents" before "Documents" or use the substituted version:
# "Important 󰈙 " = " 󰈙 "

[bun]
symbol = "🍔"
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[c]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[docker_context]
symbol = ""
style = "bg:purple fg:black"
format = '[ $symbol $context]($style)'

[kubernetes]
symbol = "󱃾"
style = "bg:purple fg:black"
format = '[ $symbol $context:$namespace ]($style)'
disabled = false

{{ if .is_work -}}
[[kubernetes.contexts]]
context_pattern = "{{ .k8s_cluster_1 }}"
context_alias = "01"

[[kubernetes.contexts]]
context_pattern = "{{ .k8s_cluster_2 }}"
context_alias = "02"

{{ end -}}

[elixir]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[elm]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[git_branch]
symbol = ""
style = "bg:green fg:black"
format = '[ $symbol $branch ]($style)'

[git_status]
style = "bg:green fg:black"
format = '[$all_status$ahead_behind ]($style)'

[golang]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[gradle]
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[haskell]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[java]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[julia]
symbol = " "
style = "bg:yellow fg:black"
format = '[ $symbol ($version) ]($style)'

[python]
symbol = '🐍 '
style = "bg:yellow fg:black"
format = '[${symbol}${pyenv_prefix}(${version} )(\($virtualenv\) )]($style)'
