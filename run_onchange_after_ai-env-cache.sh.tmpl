{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -e

# Brewfile hash: {{ include "run_onchange_before_install-packages-darwin.sh.tmpl" | sha256sum }}
#
# Triggers a rebuild of ~/.cache/ai/env.txt when the Brewfile script changes.
# The actual builder lives at ~/.local/share/ai/build-env.sh so it can also be
# invoked at runtime by the `ai` wrapper for self-healing version drift.
if [ -x ~/.local/share/ai/build-env.sh ]; then
    ~/.local/share/ai/build-env.sh
fi
{{ end -}}
