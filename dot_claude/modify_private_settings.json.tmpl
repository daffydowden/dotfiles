#!/usr/bin/env bash
# chezmoi modify_ script  →  ~/.claude/settings.json
#
# MERGES a managed key-set into the EXISTING settings.json (passed on stdin),
# rather than replacing the whole file. Keys that Claude Code and tool-installers
# write at runtime are deliberately NOT managed here, so they neither churn this
# repo nor get clobbered on `chezmoi apply`:
#     model, effortLevel, theme, syntaxHighlightingDisabled,
#     permissions (auto-accreted allow-list), hooks (aicodemetricsd / serena),
#     allowedTools, mcpServers
#
# `common` applies to every machine. The `is_work` block layers the work-only
# superset on top (worktrunk, Ref MCP, ccstatusline, the work plugin set, voice).
# Personal machines get the personal statusLine + plugin set.
set -euo pipefail

current="$(cat)"
[ -z "$current" ] && current='{}'

common='{
  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" },
  "teammateMode": "auto",
  "advisorModel": "opus",
  "editorMode": "vim",
  "verbose": true,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "ghostty",
  "language": "British English",
  "promptSuggestionEnabled": false
}'

{{ if .is_work -}}
layer='{
  "env": { "WORKTRUNK_BIN": "/Users/richarddowden/.local/bin/wt-claude" },
  "enabledMcpjsonServers": ["Ref"],
  "statusLine": { "type": "command", "command": "bunx ccstatusline@latest" },
  "extraKnownMarketplaces": { "worktrunk": { "source": { "source": "github", "repo": "max-sixty/worktrunk" } } },
  "voice": { "enabled": true, "mode": "hold" },
  "voiceEnabled": true,
  "switchModelsOnFlag": true,
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true
  }
}'
{{- else -}}
layer='{
  "autoCompactEnabled": false,
  "todoFeatureEnabled": true,
  "statusLine": { "type": "command", "command": "bash /Users/richarddowden/.claude/statusline-command.sh" },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true
  }
}'
{{- end }}

# common deep-merged with the machine layer (layer wins) -> full managed set;
# then SHALLOW-merged onto the live file so unmanaged top-level keys survive.
managed="$(jq -n --argjson c "$common" --argjson l "$layer" '$c * $l')"
printf '%s' "$current" | jq --argjson m "$managed" '. + $m'
