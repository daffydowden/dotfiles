{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "WORKTRUNK_BIN": "/Users/richarddowden/.local/bin/wt-claude"
  },
  "enabledMcpjsonServers": [
    "Ref"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/explore-prefer-serena.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/aicodemetricsd hook claude --hook-input stdin",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx ccstatusline@latest"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "language": "British English",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "promptSuggestionEnabled": false,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "editorMode": "vim",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": true,
  "todoFeatureEnabled": false,
  "teammateMode": "tmux",
  "voiceEnabled": true,
  "allowedTools": [
    "WebSearch"
  ],
  "mcpServers": {},
  "model": "sonnet[1m]"
}
