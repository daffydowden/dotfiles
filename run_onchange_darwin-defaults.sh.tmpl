{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set +x

# macOS version: {{ output "sw_vers" "--productVersion" | trim }}
{{ $macOSMajor := output "sw_vers" "--productVersion" | trim | splitList "." | first | atoi -}}
{{ range $default := .osx_defaults.defaults -}}
{{ if or (not (hasKey $default "max_macos")) (le $macOSMajor (get $default "max_macos" | int)) -}}
{{ if eq $default.type "dict-add" -}}
defaults write {{ $default.domain }} {{ $default.element }} -dict-add {{ $default.key }} "{{ $default.value }}"
{{ else -}}
defaults write {{ $default.domain }} {{ $default.element }} -{{ $default.type }} {{ $default.value }}
{{ end -}}
{{ end -}}
{{ end -}}

# cmux: DO NOT set claudeCodeCustomClaudePath to ~/bin/claude — it causes infinite
# recursion (cmux-claude-wrapper re-reads CMUX_CUSTOM_CLAUDE_PATH → shim → wrapper →
# … "Argument list too long"). Actively remove it in case a machine got the bad
# value. See docs/claude-teams-hooks-vs-splitpanes.md.
defaults delete com.cmuxterm.app claudeCodeCustomClaudePath 2>/dev/null || true

{{ range $app := .osx_defaults.kill_to_apply -}}
killall {{ $app }}
{{ end -}}

{{ end -}}
