brew "nushell"
brew "starship"

brew "zoxide"

cask "utm"
tap "trycua/lume"
brew "trycua/lume/lume"

# https://superuser.com/questions/397076/tmux-exits-with-exited-on-mac-os-x

#--------- Browsers

cask "google-chrome", args: { require_sha: false }
cask "brave-browser"

#--------- Databases

brew "postgresql"
brew "redis"
brew "memcached"

cask "datagrip"

#--------- Editors

brew "neovim"

