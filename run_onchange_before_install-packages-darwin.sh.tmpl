{{ end -}}

#--------- Misc

cask "spotify", args: { require_sha: false }

# cask "msty", args: { require_sha: false }
# cask "jan"
cask "lm-studio"
brew "aichat"

cask "positron"

#--------- AI
cask "zed"
cask "codex"
cask "codex-app"
brew "gemini-cli"
cask "claude"

brew "repomix"
brew "llm"
brew "pi-coding-agent"

