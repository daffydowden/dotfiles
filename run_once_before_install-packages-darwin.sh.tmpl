{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

brew bundle --no-upgrade --file=/dev/stdin <<EOF

# set arguments for all 'brew install --cask' commands
cask_args require_sha: true

#--------- Environment

brew "docker"
brew "colima"

brew "git"
brew "gh"
brew "tig"
brew "lazygit"

cask "kitty"
cask "ghostty"
cask "cmux"

brew "jq"
brew "miller" # jq for csv,tsv and tabular json

brew "fish" # fish shell
brew "nushell"
brew "starship"

cask "utm"
tap "trycua/lume"
brew "lume"

# https://superuser.com/questions/397076/tmux-exits-with-exited-on-mac-os-x

#--------- Browsers

cask "google-chrome", args: { require_sha: false }
cask "brave-browser"

#--------- Databases

brew "postgresql"
brew "redis"
brew "memcached"

# sqlite db editor
mas "Base - SQLite Editor", id: 402383384

cask "datagrip"

#--------- Editors

brew "neovim"

tap "d12frosted/emacs-plus"
brew "emacs-plus", args: ["with-native-comp"]

cask "visual-studio-code"

brew "pandoc"
brew "shellcheck"

cask "sublime-text"
cask "obsidian"

cask "bruno" # http client

brew "fzf"
brew "ripgrep"
brew "fd"

#--------- Fonts

# 
# https://github.com/ryanoasis/nerd-fonts/
# 

cask "font-meslo-lg-nerd-font"
cask "font-mononoki-nerd-font"
cask "font-inconsolata-nerd-font"

cask "font-fira-code-nerd-font"
cask "font-fira-mono-nerd-font"

cask "font-symbols-only-nerd-font"

#--------- Languages

# ~~ASDF~~ Mise deps
brew "coreutils" 
brew "curl" 
# Version manager
brew "mise"

brew "gpg" # for nodejs


#--------- Utils

cask "rectangle" # window manager replacement for spectacle

mas "Lungo", id: 1263070803
mas "Dashlane", id: 517914548

tap "dashlane/tap"
brew "dashlane-cli"

cask "hiddenbar" # Hide menu icons


mas "Kindle", id: 302584613

mas "Slack", id: 803453959

mas "Bear", id: 1091189122
mas "iA Writer", id: 775737590

brew "bat"
brew "tldr"
brew "eza"
brew "cbonsai"

brew "openvpn"

mas "Windows App", id: 1295203466

{{ if not .is_work -}}
#--------- Personal
brew "openhue-cli"

{{ end -}}
#--------- Misc

cask "spotify", args: { require_sha: false }

# cask "msty", args: { require_sha: false }
# cask "jan"
cask "lm-studio"
brew "aichat"

cask "positron"

#--------- AI
cask "zed"
brew "codex"
brew "gemini-cli"
cask "claude"
brew "aider"

brew "repomix"
brew "llm"

tap "charmbracelet/tap"
brew "charmbracelet/tap/crush"

EOF
{{ end -}}
